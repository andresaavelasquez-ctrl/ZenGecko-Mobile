<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <gradient android:angle="315" android:startColor="#281D36" android:endColor="#15121B" />
            <corners android:radius="18dp" />
            <stroke android:width="1dp" android:color="#7456A0" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <gradient android:angle="315" android:startColor="#17131D" android:endColor="#0D0D11" />
            <corners android:radius="18dp" />
            <stroke android:width="1dp" android:color="#332B3D" />
        </shape>
    </item>
</selector>
