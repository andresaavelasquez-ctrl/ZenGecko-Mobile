<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="#211A2B" />
            <corners android:radius="14dp" />
            <stroke android:width="1dp" android:color="#4A3B60" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <gradient android:angle="315" android:startColor="#121116" android:endColor="#09090B" />
            <corners android:radius="14dp" />
            <stroke android:width="1dp" android:color="#29252F" />
        </shape>
    </item>
</selector>
