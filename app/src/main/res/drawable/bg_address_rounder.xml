<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <solid android:color="#15121A" />
            <corners android:radius="24dp" />
            <stroke android:width="1dp" android:color="#8068BE" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <gradient android:angle="0" android:startColor="#101014"
                android:endColor="#0C0C0F" />
            <corners android:radius="24dp" />
            <stroke android:width="1dp" android:color="#302B38" />
        </shape>
    </item>
</selector>
