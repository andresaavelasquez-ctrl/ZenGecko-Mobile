<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/zen_accent_soft"/>
            <corners android:radius="16dp"/>
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/zen_surface"/>
            <corners android:radius="16dp"/>
            <stroke android:width="1dp" android:color="@color/zen_border"/>
        </shape>
    </item>
</selector>
