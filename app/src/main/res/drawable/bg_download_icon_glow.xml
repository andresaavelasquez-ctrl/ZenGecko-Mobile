<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:left="1dp" android:top="2dp" android:right="1dp" android:bottom="0dp">
        <shape android:shape="rectangle">
            <gradient android:angle="315" android:startColor="#34204F" android:centerColor="#241532" android:endColor="#130F1A" />
            <corners android:radius="16dp" />
            <stroke android:width="1dp" android:color="#72509D" />
        </shape>
    </item>
    <item android:left="5dp" android:top="5dp" android:right="5dp" android:bottom="5dp">
        <shape android:shape="rectangle">
            <gradient android:angle="270" android:startColor="#2C1A41" android:endColor="#17101F" />
            <corners android:radius="13dp" />
        </shape>
    </item>
</layer-list>
