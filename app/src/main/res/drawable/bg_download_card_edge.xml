<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <gradient android:angle="315" android:startColor="#231A30" android:endColor="#111016" />
            <corners android:radius="18dp" />
            <stroke android:width="1dp" android:color="#74579A" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <gradient android:angle="315" android:startColor="#17131E" android:centerColor="#111116" android:endColor="#0A0A0D" />
            <corners android:radius="18dp" />
            <stroke android:width="1dp" android:color="#3D334B" />
        </shape>
    </item>
</selector>
