<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/zen_accent_soft" />
            <corners android:radius="18dp" />
            <stroke android:width="1dp" android:color="@color/zen_accent" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/zen_surface_alt" />
            <corners android:radius="18dp" />
            <stroke android:width="1dp" android:color="@color/zen_border" />
        </shape>
    </item>
</selector>
