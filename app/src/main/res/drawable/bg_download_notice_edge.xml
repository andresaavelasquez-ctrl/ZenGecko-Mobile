<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <gradient android:angle="0" android:startColor="#21182D" android:centerColor="#15121C" android:endColor="#0B0B0F" />
            <corners android:radius="22dp" />
            <stroke android:width="1dp" android:color="#9A72E7" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <gradient android:angle="0" android:startColor="#191321" android:centerColor="#111016" android:endColor="#09090D" />
            <corners android:radius="22dp" />
            <stroke android:width="1dp" android:color="#57446F" />
        </shape>
    </item>
</selector>
