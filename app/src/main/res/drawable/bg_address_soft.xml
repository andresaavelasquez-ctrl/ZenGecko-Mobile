<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="#17131E" />
            <corners android:radius="17dp" />
            <stroke android:width="1dp" android:color="#4A3865" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <gradient android:angle="0" android:startColor="#111016"
                android:centerColor="#15131A" android:endColor="#111016" />
            <corners android:radius="17dp" />
            <stroke android:width="1dp" android:color="#282331" />
        </shape>
    </item>
</selector>
